# AWS CDK deploy environment for `infra/`
#
# Copy to `infra/.env` for local synth/deploy.
# These values are consumed by `infra/lib/env.ts`.

# Production app host used in S3 bucket CORS allowlist.
# Host only, no protocol.
BASE_URL=app.example.com

# OpenAI secret copied into the generated AWS Secrets Manager app secret.
# The worker later reads this from Secrets Manager at runtime.
OPENAI_API_KEY=sk-...

# Worker model configuration passed through to the deployed Lambda environment.
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_TRANSCRIPTION_STRUCTURING_MODEL=gpt-4o-mini

# Target AWS account + region for the CDK deployment.
AWS_ACCOUNT=111111111111
AWS_REGION=us-east-1

# Shared SNS alarm email. You must confirm the SNS email subscription after deploy.
AWS_ALARM_EMAIL=you@example.com

# Must match the app embedding dimension used for journal vectors.
AWS_JOURNAL_VECTOR_DIMENSION=1024
