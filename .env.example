# App runtime environment example for local development.
#
# Copy to `.env.local` (or `.env.development.local`) for local app runtime.
# In production, set the equivalent values in Vercel.

# App/auth
NODE_ENV=development
AUTH_SECRET=replace-me
VERCEL_PROJECT_PRODUCTION_URL=app.example.com
VERCEL_GIT_COMMIT_SHA=
LOG_LEVEL=info

# Optional app behavior
ADMIN_USERNAMES=sean
JOURNAL_VECTOR_TOP_K=40
JOURNAL_VECTOR_MAX_DISTANCE=0.9
MIN_JOURNAL_ANALYSIS_CHARS=40
OPENAI_JOURNAL_ANALYSIS_MODEL=gpt-4o-mini
NEXT_PUBLIC_THEME_OVERRIDE=system

# AWS app runtime credentials / resources
# These are read by `src/lib/env.server.ts`.
AWS_REGION=us-east-1
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/checklists-app
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=replace-me
AWS_BUCKET_NAME=checklists-assets-prod
AWS_JOURNAL_VECTOR_BUCKET_NAME=checklists-journal-vectors-prod
AWS_JOURNAL_VECTOR_INDEX_NAME=journal-index
AWS_JOURNAL_VECTOR_DIMENSION=1024
AWS_TABLE_NAME=checklists-prod
AWS_JOBS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/checklists-jobs-queue

# Required secret for app-side OpenAI usage (embeddings / analysis)
OPENAI_API_KEY=sk-...

# Production-only Vercel KV / Upstash values.
# Not required for local development because local dev uses the Docker Redis fallback.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# The following are worker Lambda runtime values and are normally managed by AWS CDK,
# not by the Next.js app runtime. They are listed here for reference only:
#
# AWS_REGION
# AWS_BUCKET_NAME
# AWS_TABLE_NAME
# AWS_APP_SECRET_NAME
# OPENAI_TRANSCRIPTION_MODEL
# OPENAI_TRANSCRIPTION_STRUCTURING_MODEL
# MAX_RECEIVE_ATTEMPTS
# TIMEOUT_IN_MIN
