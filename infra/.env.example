# Used for S3 bucket CORS allowlist (host only, no protocol)
# Example: app.example.com
BASE_URL=app.example.com

# Stored into the shared app secret and used by the transcription worker at runtime
OPENAI_API_KEY=sk-...

# Target AWS account + region for the stack deployment
AWS_ACCOUNT=111111111111
AWS_REGION=us-east-1

# Shared SNS alarm email (you must confirm the subscription email after deploy)
AWS_ALARM_EMAIL=john@doe.com

# S3 Vectors index dimension (must match app embedding dimension)
AWS_JOURNAL_VECTOR_DIMENSION=1024
