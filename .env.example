# Infra / CDK deploy environment (root-level reference)

# AWS account/region used by infra/bin/infra.ts
AWS_ACCOUNT=123456789012
AWS_REGION=us-east-1

# Required for the shared app secret payload (used by Lambda runtime secret fetch too)
OPENAI_API_KEY=sk-...

# Required for journal vector index in infra/lib/vector.construct.ts and app secret payload
AWS_JOURNAL_VECTOR_DIMENSION=1024

# Required shared alarm email used by infra/lib/alerts.construct.ts (SNS email subscription)
AWS_ALARM_EMAIL=you@example.com

# App runtime environment (matches src/lib/env.*)

## Required server env (src/lib/env.server.ts)
AUTH_SECRET=replace-me
AWS_REGION=us-east-1
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/checklists-app
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=replace-me
AWS_BUCKET_NAME=checklists-assets-dev
AWS_TABLE_NAME=checklists-dev
AWS_TRANSCRIPTION_JOBS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/checklists-transcription-jobs-dev
AWS_JOURNAL_VECTOR_BUCKET_NAME=checklists-journal-vectors-dev
AWS_JOURNAL_VECTOR_INDEX_NAME=journal-index
AWS_JOURNAL_VECTOR_DIMENSION=1024

## Optional server env (src/lib/env.server.ts)
# Comma-separated usernames with access to admin vector tools
ADMIN_USERNAMES=sean

## Optional shared env (src/lib/env.shared.ts)
VERCEL_PROJECT_PRODUCTION_URL=app.example.com
VERCEL_GIT_COMMIT_SHA=
LOG_LEVEL=info
JOURNAL_VECTOR_TOP_K=40
JOURNAL_VECTOR_MAX_DISTANCE=0.9
MIN_JOURNAL_ANALYSIS_CHARS=40
OPENAI_JOURNAL_ANALYSIS_MODEL=gpt-4o-mini

## Optional client env (src/lib/env.client.ts)
# one of: light | dark | system
NEXT_PUBLIC_THEME_OVERRIDE=system

# Lambda runtime environment (src/lambda/transcription-worker.ts)
# These are typically set by infrastructure on the deployed function, but useful
# to document here for local/integration execution.
AWS_APP_SECRET_NAME=checklists/app/prod
# The lambda loads OPENAI_API_KEY from AWS_APP_SECRET_NAME (Secrets Manager).
# It also reads these directly from env:
AWS_REGION=us-east-1
AWS_BUCKET_NAME=checklists-assets-dev
AWS_TABLE_NAME=checklists-dev
OPENAI_AUDIO_TRANSCRIPTION_MODEL=whisper-1
OPENAI_JOURNAL_STRUCTURING_MODEL=gpt-4o-mini
